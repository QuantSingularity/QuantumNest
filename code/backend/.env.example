# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development         # development | staging | production
DEBUG=false

# ── Security (CHANGE ALL IN PRODUCTION) ──────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-hex-string-in-production
API_SECRET_KEY=change-me-too
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (dev only)
DATABASE_URL=sqlite:///./quantumnest.db
# PostgreSQL (staging/production)
# DATABASE_URL=postgresql://postgres:password@db:5432/quantumnest

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list; use * only in development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── External APIs (optional) ─────────────────────────────────────────────────
OPENAI_API_KEY=
ALPHA_VANTAGE_API_KEY=
HUGGINGFACE_API_KEY=
QUANDL_API_KEY=
IEX_CLOUD_API_KEY=

# ── Blockchain ────────────────────────────────────────────────────────────────
ETHEREUM_RPC_URL=http://localhost:8545
POLYGON_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
PRIVATE_KEY=

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760           # 10 MB in bytes

# ── AI Models ────────────────────────────────────────────────────────────────
AI_MODELS_DIR=./models

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
