# Blockchain environment configuration
# Copy to .env and fill in real values — never commit .env to git

# ── RPC Provider ──────────────────────────────────────────────────────────────
# Local Hardhat node (used by docker-compose)
ETHEREUM_RPC_URL=http://localhost:8545

# Infura (for testnet / mainnet deployments)
INFURA_API_KEY=
INFURA_GOERLI_URL=https://goerli.infura.io/v3/${INFURA_API_KEY}
INFURA_MAINNET_URL=https://mainnet.infura.io/v3/${INFURA_API_KEY}

# ── Deployer Wallet ───────────────────────────────────────────────────────────
# Use a dedicated deployment wallet — NEVER use a wallet holding real funds
# for development/testing
PRIVATE_KEY=

# ── Contract Verification (Etherscan) ────────────────────────────────────────
ETHERSCAN_API_KEY=

# ── Network ───────────────────────────────────────────────────────────────────
NETWORK=hardhat     # hardhat | goerli | polygon_mumbai | mainnet
CHAIN_ID=31337      # 31337=hardhat | 5=goerli | 80001=mumbai | 1=mainnet
