# QuantumNest Infrastructure - Environment Variables
# Copy this file to .env and fill in all required values
# NEVER commit .env to version control

# ──────────────────────────────────────
# AWS Configuration
# ──────────────────────────────────────
AWS_DEFAULT_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# ──────────────────────────────────────
# Grafana
# ──────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_min16chars!!
GRAFANA_SECRET_KEY=changeme_32chars_random_secret!!
GRAFANA_PORT=3000

# ──────────────────────────────────────
# Elasticsearch / ELK
# ──────────────────────────────────────
ELASTIC_PASSWORD=changeme_elastic_password!!
KIBANA_PASSWORD=changeme_kibana_password!!
KIBANA_ENCRYPTION_KEY=changeme_32chars_kibana_enc_key!!
KIBANA_REPORTING_KEY=changeme_32chars_kibana_rep_key!!
KIBANA_SAVED_OBJECTS_KEY=changeme_32chars_kibana_sav_key!
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
ES_HEAP_SIZE=1g

# ──────────────────────────────────────
# Logstash
# ──────────────────────────────────────
LOGSTASH_WRITER_PASSWORD=changeme_logstash_writer_pass!!
LOGSTASH_SYSTEM_PASSWORD=changeme_logstash_system_pass!!
TRANSACTION_HASH_KEY=changeme_32chars_transaction_key!
LS_HEAP_SIZE=512m
LOGSTASH_BEATS_PORT=5044
LOGSTASH_HTTP_PORT=8080
LOGSTASH_API_PORT=9600

# ──────────────────────────────────────
# Prometheus / Alertmanager
# ──────────────────────────────────────
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8082

# ──────────────────────────────────────
# Vault (dev mode only)
# ──────────────────────────────────────
VAULT_DEV_TOKEN=changeme_vault_dev_token!!
VAULT_PORT=8200

# ──────────────────────────────────────
# PostgreSQL (local dev)
# ──────────────────────────────────────
POSTGRES_DB=quantumnest
POSTGRES_USER=quantumnest_admin
POSTGRES_PASSWORD=changeme_postgres_password!!
POSTGRES_PORT=5432

# ──────────────────────────────────────
# Redis (local dev)
# ──────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password!!
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# ──────────────────────────────────────
# Kafka (if running locally)
# ──────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_USERNAME=logstash
KAFKA_PASSWORD=changeme_kafka_password!!
